# -------------------------------------------------------
# gdelt-vector-stream — environment variable template
# Copy to .env and fill in your values. Never commit .env.
# -------------------------------------------------------

# --- Pinecone (required) ---
PINECONE_API_KEY=your-pinecone-api-key-here
PINECONE_INDEX_NAME=gdelt-events
PINECONE_ENVIRONMENT=us-east-1-aws        # e.g. us-east-1-aws, gcp-starter

# --- Embedding model (required) ---
# Options: "sentence-transformers/all-MiniLM-L6-v2"  (local, 384-dim)
#          "text-embedding-3-small"                   (OpenAI, 1536-dim)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- OpenAI (optional — only needed if EMBEDDING_MODEL is an OpenAI model) ---
OPENAI_API_KEY=sk-...

# --- GDELT polling (optional — defaults shown) ---
GDELT_POLL_INTERVAL_SECONDS=900           # 15 minutes matches GDELT update cadence

# --- Logging (optional) ---
LOG_LEVEL=INFO                            # DEBUG | INFO | WARNING | ERROR
